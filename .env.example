# Alpha Vantage API key (for stock prices and income statements)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_key_here

# Financial Modeling Prep API key (for segment revenue cross-check)
# Get free key at: https://site.financialmodelingprep.com/
FMP_API_KEY=your_key_here

# SEC EDGAR requires User-Agent header (no API key needed)
# Format: "Company Name admin@email.com"
SEC_EDGAR_USER_AGENT=YourName your.email@example.com

# Gemini API keys (for concept metadata auto-enrichment, supports multi-key rotation)
# Get key at: https://ai.google.dev/
GEMINI_API_KEY=your_key_here
GEMINI_API_KEY_1=your_key_here
GEMINI_API_KEY_2=your_key_here
GEMINI_API_KEY_3=your_key_here
GEMINI_API_KEY_4=your_key_here
GEMINI_API_KEY_5=your_key_here
GEMINI_API_KEY_6=your_key_here
GEMINI_API_KEY_7=your_key_here

# Codex API Server (optional, for remote LLM calling and smart routing)
# CODEX_API_URL=https://your-nas.ts.net:8443
# SERVER_API_KEY=your_server_key_here

# Amplitude API key (optional, for LLM call tracking via ../llm library)
# AMPLITUDE_API_KEY=your_key_here
